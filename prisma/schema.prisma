// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ProductCar {
  id            Int      @id @default(autoincrement()) @map("car_id")
  brandName     String   @map("brand_name") @db.VarChar(50)
  modelName     String   @map("model_name") @db.VarChar(100)
  trimDesc      String   @map("trim_desc") @db.VarChar(150)
  originalPrice Int      @map("original_price")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  rules         FinanceLeaseRentRule[]

  @@map("product_cars")
}

model FinanceLeaseRentRule {
  id                     Int        @id @default(autoincrement()) @map("rule_id")
  carId                  Int        @map("car_id")
  productClass           String     @map("product_class") @db.VarChar(10) // 'RENT' or 'LEASE'
  termMonths             Int        @map("term_months") // 36, 48, 60
  prepayRatio            Decimal    @default(0.30) @db.Decimal(3, 2) @map("prepay_ratio")
  residualRatio          Decimal    @db.Decimal(3, 2) @map("residual_ratio")
  calculatedMonthlyPayment Int      @map("calculated_monthly_payment")

  car                    ProductCar @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@map("finance_lease_rent_rules")
}

model Lead {
  id             String   @id @default(cuid())
  name           String
  phone          String
  car            String
  method         String
  time           String
  isContacted    Boolean  @default(false)
  missedCalls    Int      @default(0)
  createdAt      DateTime @default(now())

  @@map("leads")
}
